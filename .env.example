# ============================================================
# wecom-zoho-order-sync 环境变量模板
# 复制为 .env 后填入真实值
# ============================================================

# ---------- 运行环境 ----------
# sandbox: 指向 ZOHO 沙盒，安全测试
# production: 指向 ZOHO 正式环境，真同步
ZOHO_ENV=sandbox

# ---------- 时区 ----------
TZ=Asia/Shanghai

# ---------- 服务端口（健康检查）----------
HEALTH_PORT=3300

# ---------- 日志级别 ----------
LOG_LEVEL=debug

# ============================================================
# ZOHO CRM 凭证
# ============================================================
ZOHO_CLIENT_ID=1000.DIEF2HE10VDSWYHU5BST20AUAQUGON
ZOHO_CLIENT_SECRET=d112b5f45943b15d4110fc84a2c733b76613d6183e

# ⚠ 沙盒 refresh_token（2026-04-21 生成，scope=modules.ALL+settings.ALL+users.ALL）
ZOHO_REFRESH_TOKEN=1000.657005187c95dbed3c134f6c53ce6e70.0ebb485a2c54461aa16409b0e2a1e4f5

# 留空根据 ZOHO_ENV 自动选择
ZOHO_API_BASE_URL=
ZOHO_ACCOUNTS_URL=

ZOHO_MODULE_API_NAME=CustomModule18

# ⚠ 固定订单所有者：同步账号的 ZOHO 用户邮箱
# 服务启动时会用这个邮箱反查 user_id 并缓存
# 沙盒：zoho@inotary.com.hk (Admin, user_id=216300000000495002)
# 正式：待确认 Jacky 在正式环境的邮箱（沙盒里没 jacky@inotary.com.hk）
ZOHO_DEFAULT_OWNER_EMAIL=zoho@inotary.com.hk

# 可选：直接指定 user_id 跳过反查（沙盒推荐，省一次 API 调用）
ZOHO_DEFAULT_OWNER_ID=216300000000495002

# 默认币种（主表没这列，统一默认 RMB）
ZOHO_DEFAULT_CURRENCY=RMB

# ⚠ ZOHO 写入串行间隔（毫秒）
# ZOHO 写入节流：本地生成文件编号后，autonumber/workflow 串行依赖已去除
# 默认 0（不限速），由 ZOHO_CONCURRENCY 控制并发上限即可
# 如果未来又遇到限流/重复，可临时调到 1000~3000ms
ZOHO_WRITE_INTERVAL_MS=0

# 并发度：本地生成文件编号 + 客户编号缓存后，可以并发跑
# 沙盒 ~5 QPS，正式 ~10 QPS；4 是经验稳定值，太大会触发 429
# 改回 1 即退化为严格串行
ZOHO_CONCURRENCY=4

# 失败通知去抖：同一行连续失败超过此次数后不再发企微通知（仍写 DB + 状态列）
# 重置规则：修改业务内容（hash 变了）才重置计数；仅清"导入状态"列不算（还是同一份坏数据）
# 默认 5：第 1-5 次失败会通知，第 6 次起静默直到内容被修正
MAX_NOTIFY_ATTEMPTS=5

# 可选：技术唯一键字段（用于按企微 record_id 反查 ZOHO，兜底去重）
# 不能等于 field235（业务字段「订单确认编号」），留空表示仅靠本地 SQLite + business_key 去重
ZOHO_TECHNICAL_KEY_FIELD_API_NAME=

# ============================================================
# 企业微信 - 自建应用（小智）
# ============================================================
WECOM_CORP_ID=ww077b2e151608dee9
WECOM_AGENT_ID=1000101
WECOM_AGENT_SECRET=Wm3czfaUyzjIUqLLqqQo0X2xBuoiit0JeaS1rCIiP6s

# 消息推送范围：默认 @all（应用可见范围内所有人）
# 也可以指定用户，用 | 分隔，例如：Jacob|Chris|Eleson
WECOM_NOTIFY_TO=@all

# ============================================================
# 企业微信 - 智能表格（销售订单导入）
# ============================================================
# 完整链接：https://doc.weixin.qq.com/smartsheet/s3_ADkAIRRBADUCNNEpbNHvnRzGiAxiQ_a?scode=...&tab=q979lj&viewId=vukaF8
WECOM_SHEET_DOCID=s3_ADkAIRRBADUCNNEpbNHvnRzGiAxiQ_a
WECOM_SHEET_TAB=q979lj
WECOM_SHEET_VIEW_ID=vukaF8

# ============================================================
# 轮询配置
# ============================================================
# 轮询间隔（分钟）
POLL_INTERVAL_MINUTES=2

# 每轮最多处理的行数
POLL_MAX_ROWS=200

# ============================================================
# 数据库
# ============================================================
DB_PATH=./data/orders.db

# ============================================================
# 汇总报告时间
# ============================================================
DAILY_REPORT_CRON=0 9 * * *

# ============================================================
# 企微回调（暂未接入 — 等同步功能测试稳定后再启用）
# 配好这两个值并在 src/index.js 启动 wecom-callback 服务即可
# ============================================================
# 在企微管理后台「应用 > 接收消息」配置时填的 Token
WECOM_CALLBACK_TOKEN=
# 在企微管理后台配置的 EncodingAESKey（43位）
WECOM_CALLBACK_AES_KEY=
# 回调服务监听端口
WECOM_CALLBACK_PORT=3301
